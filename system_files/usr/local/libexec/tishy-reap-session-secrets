#!/usr/bin/env bash

# Reap a niri session's KWallet Secret-Service daemon (ksecretd) as the session
# ends, so KWallet keeps working across a niri restart.
#
# KWallet exposes org.freedesktop.secrets through ksecretd. plasmalogin's PAM
# stack launches one `ksecretd --pam-login` per login -- unlocked with the login
# password -- inside the logind session scope (session-$XDG_SESSION_ID.scope).
# systemd-logind here runs with KillUserProcesses=no, so when a niri session ends
# its scope is NOT torn down: the old ksecretd lives on and the logind session
# wedges in state "closing". The *next* login's `ksecretd --pam-login` then loses
# the race to register org.freedesktop.secrets against that lingering instance and
# ends up owning no bus name at all. With the name unclaimed, the first portal
# Secret request D-Bus-activates a fresh, password-less ksecretd (the kwallet
# portal backend, Exec=/usr/bin/ksecretd with no --pam-login). That instance
# grabs org.freedesktop.secrets but cannot unlock the wallet -- so KWallet
# "stops working" after every manual niri restart.
#
# This script breaks the cycle by making each session clean up after itself. It
# runs from niri.service ExecStopPost, where XDG_SESSION_ID still names the ending
# session, and reaps three things:
#
#   1. This ending session's own `ksecretd --pam-login`, so the scope empties and
#      logind can finalize the close. This is what keeps a stale instance from
#      poisoning the next login's name registration.
#   2. Any password-less ksecretd (no --pam-login), wherever it lives -- the
#      D-Bus-activated hijacker, so a broken state never survives into the next
#      session.
#   3. Any `ksecretd --pam-login` stranded in a logind session that is already
#      "closing" or gone, which self-heals scopes leaked before this fix landed
#      (or by an unclean exit) without waiting for a manual pkill.
#
# A `ksecretd --pam-login` belonging to another *live* session is deliberately
# left alone. kwalletd6 is also left alone: it is a shared, D-Bus-activated
# singleton (not per-session) that flushes secrets to disk on its own, so killing
# it here would risk losing unsaved entries for no benefit.
#
# Safety: niri.service is Restart=no, so every stop is followed by a fresh
# plasmalogin login that respawns ksecretd via PAM -- there is no path where this
# leaves a real session permanently without a Secret Service. (A manual
# `systemctl --user restart niri.service`, which skips PAM, is the one exception;
# that is not how this box restarts niri, and it recovers on the next login.)
#
# Identifying "this session" relies on XDG_SESSION_ID, which assumes a single
# concurrent niri session -- true for this machine. With two niri sessions sharing
# the user manager, clause 1 could target the wrong scope; clauses 2 and 3 stay
# correct regardless.
#
# Set TISHY_REAP_DRY_RUN=1 to log what would be reaped without killing anything.

set -euo pipefail

my_session="${XDG_SESSION_ID:-}"
dry_run="${TISHY_REAP_DRY_RUN:-0}"

# A logind session counts as dead if it is gone entirely or stuck "closing".
session_is_dead() {
    local sid="$1" state
    state=$(loginctl show-session "$sid" -p State --value 2>/dev/null) || return 0
    [[ -z "$state" || "$state" == "closing" ]]
}

reap() {
    local pid="$1" why="$2"
    if [[ "$dry_run" == "1" ]]; then
        echo "tishy-reap-session-secrets: WOULD reap ksecretd pid=$pid ($why)" >&2
    else
        echo "tishy-reap-session-secrets: reaping ksecretd pid=$pid ($why)" >&2
        kill "$pid" 2>/dev/null || true
    fi
}

pids=$(pgrep -x ksecretd 2>/dev/null || true)
for pid in $pids; do
    cmdline=$(tr '\0' ' ' < "/proc/$pid/cmdline" 2>/dev/null || true)
    cgroup=$(cat "/proc/$pid/cgroup" 2>/dev/null || true)
    [[ -n "$cmdline" ]] || continue

    # Clause 2: a password-less ksecretd is a D-Bus-activated hijacker. Always reap.
    if [[ "$cmdline" != *--pam-login* ]]; then
        reap "$pid" "password-less D-Bus-activated instance"
        continue
    fi

    # Pull the logind session id out of a session-N.scope cgroup, if present.
    sid=""
    if [[ "$cgroup" == *session-*.scope* ]]; then
        sid="${cgroup##*session-}"
        sid="${sid%%.scope*}"
    fi
    # A --pam-login ksecretd outside any session scope: not ours to judge; leave it.
    [[ -n "$sid" ]] || continue

    if [[ -n "$my_session" && "$sid" == "$my_session" ]]; then
        # Clause 1: this ending session's own instance.
        reap "$pid" "this session ($sid) is ending"
    elif session_is_dead "$sid"; then
        # Clause 3: stranded in an already closing/gone session.
        reap "$pid" "session $sid is closing/gone"
    fi
    # Otherwise: a --pam-login ksecretd in another live session. Leave it.
done

exit 0
